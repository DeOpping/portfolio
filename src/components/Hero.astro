---
import Icon from './Icon.astro';
import { faDownload } from '@fortawesome/free-solid-svg-icons';
---

<section class="hero">
	<div class="hero-content">

		<h1>Nicholas Call</h1>
		<h2>Gameplay Programmer</h2>

		<p>
			Game Developer student passionate about game development,
			and building high-performance software.
		</p>

		<div class="buttons">
			<a href="#projects" class="primary">
				View Projects
			</a>

			<a href="/NicholasCall_Resume.pdf" class="secondary" target="_blank">
				<span class="icon"><Icon iconDefinition={faDownload} /></span>
				Resume
			</a>
		</div>

	</div>
</section>

<style>
.hero {
	min-height: 100vh;
	display: flex;
	justify-content: center;
	align-items: center;
	text-align: center;
	padding: 6rem 2rem 2rem;
}

.hero-content {
	max-width: 750px;
}

.hero h1 {
	font-size: 4rem;
	margin-bottom: .5rem;
}

.hero h2 {
	color: var(--primary);
	font-size: 2rem;
	font-weight: 500;
	margin-bottom: 1.5rem;
}

.hero p {
	font-size: 1.2rem;
	color: var(--text-secondary);
	line-height: 1.7;
	margin-bottom: 2rem;
}

.buttons {
	display: flex;
	justify-content: center;
	gap: 1rem;
	flex-wrap: wrap;
}

.buttons a {
	padding: .9rem 1.6rem;
	border-radius: 10px;

	display: flex;
	align-items: center;
	justify-content: center;
	gap: .5rem;
	white-space: nowrap;

	font-weight: 600;
	transition: .25s;
}

.primary {
	background: var(--primary);
	color: var(--background);
}

.primary:hover {
	transform: translateY(-2px);
}

.secondary {
	border: 1px solid var(--primary);
}

.secondary:hover {
	background: var(--surface);
}
</style>